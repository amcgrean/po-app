{
  "name": "po-checkin-app",
  "version": "1.5.1",
  "description": "Custom PO Check In Sheet Manager for Agility with Acknowledgement Review",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -m ./node_modules/better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "electron-builder --win nsis",
    "build": "electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "chokidar": "^4.0.3",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "mssql": "^10.0.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "postinstall": "^0.11.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.yourcompany.pocheckin",
    "productName": "PO Check In Manager",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    }
  }
}
